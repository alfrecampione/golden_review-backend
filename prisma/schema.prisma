generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["goldenaudit"]
}

// Tabla de sesiones de Fastify (para cookies HTTP)
model session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
  @@schema("goldenaudit")
}

// Users table
model User {
  id           String        @id @default(uuid())
  microsoftId  String?       @unique
  email        String        @unique
  firstName    String?
  lastName     String?
  fullName     String?
  department   String?
  position     String?
  roles        String[]      @default([])
  lastAccess   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userCarriers UserCarrier[]
  userPolicies UserPolicy[]

  @@map("user")
  @@schema("goldenaudit")
}

model UserCarrier {
  id        String   @id @default(uuid())
  userId    String
  carrierId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, carrierId], map: "user_carrier_user_id_carrier_id_key")
  @@map("user_carrier")
  @@schema("goldenaudit")
}

model UserPolicy {
  id         String   @id @default(uuid())
  userId     String?
  policyId   String   @unique
  autoAssign Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_policy")
  @@schema("goldenaudit")
}

// Authentication logs table
model AuthLog {
  id            String   @id @default(uuid())
  email         String
  isSuccessful  Boolean
  failureReason String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("auth_log")
  @@schema("goldenaudit")
}

model UpdatePolicyJobLog {
  id        String   @id @default(uuid())
  policyIds Json     @db.Json
  count     Int
  createdAt DateTime @default(now())

  @@map("update_policy_job_log")
  @@schema("goldenaudit")
}

model FileSyncJobLog {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now()) @map("created_at")
  processedLogIds Json // Array of UpdatePolicyJobLog IDs that were processed
  customerCount   Int
  policyCount     Int

  @@map("file_sync_job_logs")
  @@schema("goldenaudit")
}

model UserApplication {
  id          String   @id @default(uuid())
  customerId  Int      @unique
  fileId      String
  isProcessed Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("user_application")
  @@schema("goldenaudit")
}

model TempJSONStorage {
  id         String   @id @default(uuid())
  customerId Int      @unique
  data       Json     @db.Json
  createdAt  DateTime @default(now())

  @@map("temp_json_storage")
  @@schema("goldenaudit")
}

model CustomerDocument {
  id         String   @id @default(uuid())
  customerId Int
  fileId     String
  type       String // declaration_page, application, id_card, other
  carrier    String
  confidence Float
  data       Json     @db.Json
  createdAt  DateTime @default(now())

  @@map("customer_document")
  @@schema("goldenaudit")
}
